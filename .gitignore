# =============================================================================
# .gitignore — DDoS Reduction Project
# =============================================================================

# =============================================================================
# Rust / Cargo (Stage 1)
# =============================================================================
stage1/src/testing_results.txt
attachments/*

# Build output — the target/ directory is large (hundreds of MB) and fully
# reproducible with `cargo build`. Never commit it.
stage1/target/

# Cargo lock file for binaries (keep for libraries, but this is a binary crate).
# Committing Cargo.lock is recommended for reproducible builds — remove this
# line if you want lock-file pinning in CI.
# stage1/Cargo.lock   ← intentionally NOT ignored (keep for reproducibility)

# Cargo registry cache (downloaded crate sources — machine-local)
.cargo/

# =============================================================================
# Python / Stage 2 (future)
# =============================================================================

# Byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environment directories
.venv/
venv/
env/
.env/

# Environment variable files (may contain secrets / paths)
.env
.env.*
!.env.example

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Trained ML model binaries (can be large — store in a model registry instead)
*.pkl
*.joblib
*.h5
*.pt
*.pth
stage2/models/

# Training data (often large and/or sensitive — store separately)
stage2/data/
*.csv
*.parquet
*.pcap
*.pcapng

# =============================================================================
# Runtime / IPC artefacts
# =============================================================================

# Unix domain socket file left behind after an unclean shutdown
*.sock
/tmp/ddos_stage1.sock

# Log files generated by the gateway
*.log
logs/

# PID files (created by some daemonisation wrappers)
*.pid

# =============================================================================
# OS-generated files
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# =============================================================================
# Editor / IDE files
# =============================================================================

# VSCode (keep .vscode/extensions.json if you want to share recommended extensions,
# but workspace settings and launch configs are machine-specific)
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.vscode/*.code-workspace

# JetBrains (CLion, IntelliJ, PyCharm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*.swn
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# Sublime Text
*.sublime-workspace
*.sublime-project

# =============================================================================
# Sensitive / deployment-specific files
# =============================================================================

# Any file containing keys, passwords, or tokens
secrets/
*.key
*.pem
*.crt
*.p12
*.pfx

# Ansible / deployment inventory files (contain IP addresses of real VMs)
inventory/
hosts

# Proxmox VM configuration exports
*.conf.bak

# =============================================================================
# Miscellaneous
# =============================================================================

# Compressed archives (usually generated artefacts, not source)
*.tar.gz
*.zip
*.7z
*.rar

# Coverage reports
coverage/
htmlcov/
.coverage
*.cover

# Benchmarking output
criterion/
flamegraph.svg
perf.data
perf.data.old

false_positives_analysis.txt
next_focus_items.txt